// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String?
  role       String   @default("MECHANIC") // "SUPER_ADMIN" or "MECHANIC"
  createdAt  DateTime @default(now())
  lastLogin  DateTime?
  lastDevice String?

  diagnostics Diagnostic[]
}

model Diagnostic {
  id         String   @id @default(cuid())
  userId     String
  type       String   @default("obd") // "obd" or "osciloscopio"
  vehicle    String
  parameters String   // Stored as JSON string
  diagnosis  String
  image      String?  @db.Text
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DiagnosticCache {
  hash       String   @id
  response   String
  createdAt  DateTime @default(now())
}

model Oficina {
  numeroCliente String   @id
  nome          String?
  nif           String?
  
  vendaMesAnterior Float?
  vendaMesAtual    Float?
  tendenciaRisco   Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  contactos     Contacto[]
  visitas       Visita[]
  vendas        Venda[]
}

model Contacto {
  id             String   @id @default(cuid())
  numeroCliente  String
  nome           String?
  telefone       String?
  email          String?
  
  oficina        Oficina  @relation(fields: [numeroCliente], references: [numeroCliente], onDelete: Cascade)
}

model Visita {
  id             String   @id @default(cuid())
  numeroCliente  String
  data           DateTime @default(now())
  notas          String?
  status         String   @default("PENDENTE")
  
  oficina        Oficina  @relation(fields: [numeroCliente], references: [numeroCliente], onDelete: Cascade)
}

model Venda {
  id             String   @id @default(cuid())
  numeroCliente  String
  valor          Float
  data           DateTime @default(now())
  
  oficina        Oficina  @relation(fields: [numeroCliente], references: [numeroCliente], onDelete: Cascade)
}

model RateLimit {
  id        String   @id @default(cuid())
  ip        String
  endpoint  String   @default("diagnose")
  createdAt DateTime @default(now())
}

model VinCache {
  vin       String   @id
  marca     String
  modelo    String
  ano       String
  motor     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
